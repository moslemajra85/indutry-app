{
  "name": "industry-ops-ai",
  "version": "0.1.0",
  "private": true,
  "description": "Modular monolith factory operations platform with TypeScript, Express, PostgreSQL, Docker, and optional local AI.",
  "scripts": {
    "dev:api": "tsx watch src/server.ts",
    "dev:web": "vite --config web/vite.config.ts --host 0.0.0.0",
    "build": "npm run build:api && npm run build:web",
    "build:api": "tsc -p tsconfig.server.json",
    "build:web": "vite build --config web/vite.config.ts",
    "start": "node dist/server.js",
    "start:prod": "node dist/infra/database/migrate.js && node dist/server.js",
    "db:migrate": "tsx src/infra/database/migrate.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit -p tsconfig.server.json && tsc --noEmit -p web/tsconfig.json"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "helmet": "^7.1.0",
    "pg": "^8.12.0",
    "pino": "^9.3.2",
    "pino-http": "^10.2.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.10",
    "@types/pg": "^8.11.6",
    "pino-pretty": "^11.2.2",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  }
}
